{
  "permissions": {
    "allow": [
      "Bash(npx vitest run *)",
      "Bash(npm test *)",
      "Bash(npm run typecheck)",
      "Bash(npx prettier *)",
      "Agent(Explore)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'set -o pipefail; npm run typecheck && npm test 2>&1 | tail -25' && echo '{\"systemMessage\": \"typechecks and tests passing\"}' || exit 2",
            "statusMessage": "Type-checking and running tests...",
            "timeout": 120,
            "asyncRewake": true,
            "rewakeSummary": "Typecheck/test failures detected"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx vitest run --reporter=json --silent=passed-only 2>/dev/null | jq '[.testResults[].assertionResults[] | select(.status == \"failed\")]' | grep -v '^\\[\\]$' || true",
            "statusMessage": "Running tests...",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
