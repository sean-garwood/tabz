{
  "name": "tabz",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dist": "npm run build && zip -r tabz.zip manifest.json config.json options.html options.css dist/",
    "fmt": "prettier --write '**/*.{css,html,json,md,ts}'",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
